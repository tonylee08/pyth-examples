# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Loaded automatically by `pnpm run start:post_sui` via Node's --env-file flag.

# Pyth Lazer API token. Must be entitled to crypto feeds.
# Get one at https://pythdata.app
ACCESS_TOKEN=

# Sui ed25519 private key in bech32 form (starts with `suiprivkey1...`).
# Export with: sui keytool export --key-identity $(sui client active-address)
SUI_PRIVATE_KEY=

# Object id returned by `sui client publish` for lazer/sui.
PACKAGE_ID=

# Object id of the shared `PriceStore` returned by `create_store`.
STORE_ID=

# Pyth-managed shared State object id for the on-chain Lazer verifier.
# Owned and rotated by Pyth — your contract never touches it directly; the JS
# publisher passes it to `addParseAndVerifyLeEcdsaUpdateCall` in the PTB.
# Source: contract_manager/src/store/contracts/SuiLazerContracts.json in
# pyth-network/pyth-crosschain (mainnet on `main`, testnet on `sui-testnet`).
#   Testnet: 0xe2b9096a5ea341a9f1eef126b2203727e29e73fdb0641ade2e1e32942f97e4d8
#   Mainnet: 0xd0db9c1e9212a98120384bf78d8b8c985d87b9ee6921dffcf9d1394062911573
PYTH_LAZER_STATE_ID=

# Optional: defaults shown below.
# SUI_NETWORK=testnet
# POST_INTERVAL_MS=1000
