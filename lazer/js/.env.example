# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Loaded automatically by `pnpm run start:post_sui` via Node's --env-file flag.

# Pyth Lazer API token. Must be entitled to crypto feeds.
# Get one at https://pythdata.app
ACCESS_TOKEN=

# Sui ed25519 private key in bech32 form (starts with `suiprivkey1...`).
# Export with: sui keytool export --key-identity $(sui client active-address)
SUI_PRIVATE_KEY=

# Object id returned by `sui client publish` for lazer/sui.
PACKAGE_ID=

# Object id of the shared `PriceStore` returned by `create_store`.
STORE_ID=

# Optional: defaults shown below.
# SUI_NETWORK=testnet
# POST_INTERVAL_MS=1000
